# Dependencies
**/node_modules/

# Build output
**/dist/
**/.vitepress/cache/
**/dist-exe/
**/*.tsbuildinfo
hub/src/web/embeddedAssets.generated.ts
hub/src/generated/

# Downloaded tools (fetched at build time)
shared/tools/tunwg/tunwg-*
shared/tools/tunwg/*.exe

# Env files (can contain secrets)
**/.env
**/.env.*
**/.env*.local

# Logs
**/*.log
**/*-debug.log
**/*-error.log
npm-debug.log*

# Coverage
coverage/

# OS / IDE
**/.DS_Store
.idea/
.vscode/
**/*.swp
**/*.swo

# Claude local settings
.claude/settings.local.json
localdocs/
execplan/

# Generated npm bundle output (local)
cli/npm/main/
.ace-tool/
