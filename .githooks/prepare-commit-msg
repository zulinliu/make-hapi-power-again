#!/usr/bin/env bash
# prepare-commit-msg hook: auto-strip Co-Authored-By lines
# Blocks Claude Code / HAPI injected co-author markers
COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Skip merge commits
if [ "$COMMIT_SOURCE" = "merge" ]; then
    exit 0
fi

# Use perl slurp mode (-0777) with multiline matching (/m)
# Handles co-author lines with leading spaces or tabs
perl -0777 -pi -e 's/^[ \t]*Co-Authored-By:.*\n//gm' "$COMMIT_MSG_FILE"
perl -0777 -pi -e 's/^[ \t]*via \[HAPI\].*\n//gm' "$COMMIT_MSG_FILE"
perl -0777 -pi -e 's/^[ \t]*via \[Claude Code\].*\n//gm' "$COMMIT_MSG_FILE"
perl -0777 -pi -e 's/^[ \t]*Generated with \[.*\n//gm' "$COMMIT_MSG_FILE"

# Collapse trailing blank lines
perl -0777 -pi -e 's/\n{3,}$/\n\n/' "$COMMIT_MSG_FILE"
